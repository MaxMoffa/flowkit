{
  "name": "@flowkit/themes",
  "version": "0.1.0",
  "description": "Design tokens and CSS variables themes for Flowkit (default: notion-clean).",
  "license": "MIT",
  "author": "Massimo Moffa",
  "homepage": "https://github.com/MaxMoffa/flowkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxMoffa/flowkit.git",
    "directory": "packages/themes"
  },
  "keywords": ["flowkit", "theme", "design-tokens"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "devDependencies": {
    "tsup": "^8.3.5"
  }
}
