{
  "name": "@flowkit-io/presets",
  "version": "0.2.0",
  "description": "Ready-made Flowkit flow configs (surveys, feedback, etc).",
  "license": "MIT",
  "author": "Massimo Moffa",
  "homepage": "https://github.com/MaxMoffa/flowkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxMoffa/flowkit.git",
    "directory": "packages/presets"
  },
  "keywords": ["flowkit", "preset", "survey", "feedback"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@flowkit-io/core": "^0.2.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5"
  }
}
