{
  "name": "@flowkit/react",
  "version": "0.1.0",
  "description": "React renderer and step components for Flowkit.",
  "license": "MIT",
  "author": "Massimo Moffa",
  "homepage": "https://github.com/MaxMoffa/flowkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxMoffa/flowkit.git",
    "directory": "packages/react"
  },
  "keywords": ["flowkit", "react", "form", "wizard"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./src/style.css",
    "./map-maplibre": {
      "types": "./dist/map-maplibre.d.ts",
      "import": "./dist/map-maplibre.js"
    },
    "./map-leaflet": {
      "types": "./dist/map-leaflet.d.ts",
      "import": "./dist/map-leaflet.js"
    }
  },
  "files": ["dist", "src/style.css"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.tsx src/map-maplibre.ts src/map-leaflet.ts --format esm --dts --clean --external react --external react-dom"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "maplibre-gl": "^4.7.1",
    "leaflet": "^1.9.4"
  },
  "peerDependenciesMeta": {
    "maplibre-gl": { "optional": true },
    "leaflet": { "optional": true }
  },
  "dependencies": {
    "@flowkit/core": "^0.1.0",
    "@flowkit/themes": "^0.1.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5"
  }
}
