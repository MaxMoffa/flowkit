{
  "name": "@flowkit-io/core",
  "version": "0.2.0",
  "description": "Headless config schema, flow state machine, validation and i18n for Flowkit.",
  "license": "MIT",
  "author": "Massimo Moffa",
  "homepage": "https://github.com/MaxMoffa/flowkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxMoffa/flowkit.git",
    "directory": "packages/core"
  },
  "keywords": ["flowkit", "form", "wizard", "flow", "config"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5"
  }
}
